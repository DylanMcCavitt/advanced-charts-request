{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chartreviewlab.company/docs/schemas/review_artifact_v1.schema.json",
  "title": "Chart Review Lab review_artifact_v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "symbol",
    "resolution",
    "timeframe",
    "dataSource",
    "candleSource",
    "generatedAt",
    "sourceMetadata",
    "caveats",
    "viewerState",
    "annotations"
  ],
  "properties": {
    "kind": {
      "const": "review_artifact_v1"
    },
    "symbol": {
      "type": "string",
      "minLength": 1
    },
    "resolution": {
      "type": "string",
      "minLength": 1
    },
    "timeframe": {
      "type": "string",
      "minLength": 1
    },
    "dataSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "feed", "baseUrl", "historyUrl"],
      "properties": {
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "feed": {
          "type": "string",
          "minLength": 1
        },
        "baseUrl": {
          "type": "string",
          "minLength": 1
        },
        "historyUrl": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "candleSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "bars", "windowStart", "windowEnd", "latestBarTime", "stale"],
      "properties": {
        "mode": {
          "enum": ["server_datafeed", "linked_public_datafeed"]
        },
        "bars": {
          "type": "integer",
          "minimum": 0
        },
        "windowStart": {
          "type": ["string", "null"]
        },
        "windowEnd": {
          "type": ["string", "null"]
        },
        "latestBarTime": {
          "type": ["string", "null"]
        },
        "stale": {
          "type": "boolean"
        }
      }
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "sourceMetadata": {
      "$ref": "#/$defs/reviewPrimitiveRecord"
    },
    "caveats": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "viewerState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["visibleFilter", "selectedAnnotationId"],
      "properties": {
        "visibleFilter": {
          "type": "string",
          "minLength": 1
        },
        "selectedAnnotationId": {
          "type": ["string", "null"]
        }
      }
    },
    "annotations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/annotation"
      }
    }
  },
  "$defs": {
    "annotation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "group", "type", "label", "color", "summary", "values", "draw", "source"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "group": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "enum": [
            "horizontal_level",
            "range_box",
            "fib_style_levels",
            "measured_projection",
            "text_labels"
          ]
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "color": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "values": {
          "$ref": "#/$defs/reviewPrimitiveRecord"
        },
        "draw": {
          "type": "object",
          "propertyNames": {
            "$ref": "#/$defs/reviewOnlyPropertyName"
          }
        },
        "source": {
          "$ref": "#/$defs/reviewPrimitiveRecord"
        }
      }
    },
    "reviewPrimitiveRecord": {
      "type": "object",
      "propertyNames": {
        "$ref": "#/$defs/reviewOnlyPropertyName"
      },
      "additionalProperties": {
        "type": ["string", "number", "boolean", "null"]
      }
    },
    "reviewOnlyPropertyName": {
      "not": {
        "pattern": "^(score|recommendation|alert|candidate|candidate[_-]?rank|rank|order|position|account|execution|broker|brokers|portfolio|signal)$"
      }
    }
  }
}
